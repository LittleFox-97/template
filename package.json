{
  "name": "@fabiospampinato/template",
  "type": "module",
  "version": "2.3.1",
  "packageManager": "pnpm@10.22.0",
  "description": "A super-simple way to create new projects based on templates.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabiospampinato/template.git"
  },
  "keywords": [
    "template",
    "scaffold",
    "handlebars",
    "picolate",
    "cli",
    "simple"
  ],
  "exports": "./dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "template": "dist/bin.js"
  },
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "clean": "rimraf dist",
    "prebuild": "clean",
    "build": "clean && lint:fix && tsc",
    "build:watch": "tsc --watch",
    "test": "fava",
    "test:watch": "fava --watch",
    "dev": "build:watch & test:watch",
    "start": "node dist/bin.js"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "cac": "^6.7.14",
    "json-archive": "^2.1.0",
    "picolate": "^2.2.0",
    "prask": "^2.2.3",
    "radix64-encoding": "^2.0.2",
    "remeda": "^2.32.0",
    "specialist": "^1.4.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "fava": "^0.3.5",
    "rimraf": "^6.1.0",
    "typescript": "^5.9.3"
  }
}
