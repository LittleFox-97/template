{
  "name": "@fabiospampinato/template",
  "type": "module",
  "version": "2.3.1",
  "packageManager": "pnpm@10.18.1",
  "description": "A super-simple way to create new projects based on templates.",
  "repository": "github:fabiospampinato/template",
  "keywords": [
    "template",
    "scaffold",
    "handlebars",
    "picolate",
    "cli",
    "simple"
  ],
  "exports": "./dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": "dist/bin.js",
  "scripts": {
    "clean": "node -e \"const fs = require('fs'); if (fs.existsSync('dist')) fs.rmSync('dist', { recursive: true, force: true });\"",
    "compile": "tsc",
    "compile:watch": "tsc --watch",
    "test": "node --test test/**/*.js",
    "test:watch": "node --test --watch test/**/*.js",
    "prepublishOnly": "npm run clean && npm run compile",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "node dist/bin.js"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "inquirer": "^12.9.6",
    "json-archive": "^2.1.0",
    "lodash": "^4.17.21",
    "picolate": "^2.2.0",
    "radix64-encoding": "^2.0.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.7.0",
    "eslint": "^9.37.0",
    "typescript": "^5.9.3"
  }
}
